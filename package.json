{
  "name": "cab-booking-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend/*",
    "backend/api-gateway",
    "backend/microservices/*",
    "packages/*"
  ],
  "scripts": {
    "dev:customer": "yarn workspace @cab/customer-app dev",
    "dev:driver": "yarn workspace @cab/driver-app dev",
    "dev:admin": "yarn workspace @cab/admin-dashboard dev",
    "dev:all": "concurrently \"yarn dev:customer\" \"yarn dev:driver\" \"yarn dev:admin\"",
    "build:all": "yarn workspaces run build",
    "lint": "yarn workspaces run lint",
    "type-check": "yarn workspaces run type-check",
    "test:lv1": "node tests/verify_lv1.js",
    "test:lv2": "node tests/verify_lv2.js",
    "test:lv3": "node tests/verify_lv3.js",
    "test:lv4": "node tests/verify_lv4.js",
    "test:lv5": "node tests/verify_lv5.js",
    "test:lv6": "node tests/verify_lv6.js",
    "test:all": "node tests/run-ci-tests.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prisma": "^6.19.3",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "react-leaflet": "^4.2.1"
  }
}
