// prisma/schema.prisma — Booking Service (MongoDB)
// Port: 3002

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  driverId    String?  @map("driver_id")
  pickupLat   Float    @map("pickup_lat")
  pickupLng   Float    @map("pickup_lng")
  dropLat     Float    @map("drop_lat")
  dropLng     Float    @map("drop_lng")
  distanceKm  Float    @map("distance_km")
  price       Int
  pickupAddress   String?  @map("pickup_address")
  dropoffAddress  String?  @map("dropoff_address")
  driverEta       Int?     @map("driver_eta")
  surgeMultiplier Float?   @map("surge_multiplier")
  paymentId       String?  @map("payment_id")
  notificationSent Boolean @default(false) @map("notification_sent")
  paidAt          DateTime? @map("paid_at")
  cancelledAt     DateTime? @map("cancelled_at")
  status          String   @default("REQUESTED")
  idempotencyKey  String?  @unique @map("idempotency_key")
  version         Int      @default(0)
  failureReason   String?  @map("failure_reason")
  matchingReason  String?  @map("matching_reason")
  mcpContext      Json?    @map("mcp_context")
  vehicleType     String   @default("car") @map("vehicle_type")
  paymentMethod   String   @default("CASH") @map("payment_method")
  paymentStatus   String   @default("PENDING") @map("payment_status")
  isFallback      Boolean  @default(false) @map("is_fallback")
  retryAttempts   Int      @default(0) @map("retry_attempts")
  retryStrategy   String?  @map("retry_strategy")
  pricingStatus   String?  @map("pricing_status")
  fallbackSource  String?  @map("fallback_source")
  pricingError    String?  @map("pricing_error")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("bookings")
}

model Outbox {
  id        String   @id @default(uuid())
  topic     String
  payload   String   // JSON string
  status    String   @default("PENDING") // PENDING, PROCESSED, FAILED
  createdAt DateTime @default(now()) @map("created_at")
  idempotencyKey String? @unique @map("idempotency_key")

  @@map("outbox")
}
