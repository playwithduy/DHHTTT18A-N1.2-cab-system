# ============================================================
# .env.example — Copy to .env.local for each app
# ============================================================

# ── API Gateway ──────────────────────────────────────────────
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=http://localhost:8080

# ── Map (get free token at mapbox.com) ───────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOiJjbG...

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-at-least-32-characters-long!!

# ── Databases (docker-compose sets these automatically) ───────
DATABASE_URL=postgresql://cabgo:cabgo_secret@localhost:5432/cabgo
MONGO_URI=mongodb://cabgo:cabgo_secret@localhost:27017/cabgo
REDIS_URL=redis://:cabgo_redis@localhost:6379

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── Payments ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Push Notifications ────────────────────────────────────────
FCM_SERVER_KEY=your_firebase_server_key

# ── App ports ─────────────────────────────────────────────────
CUSTOMER_APP_PORT=3100
DRIVER_APP_PORT=3200
ADMIN_DASHBOARD_PORT=3300
API_GATEWAY_PORT=8080
