{
	"info": {
		"_postman_id": "level8-full-resilience",
		"name": "LEVEL 8 – FAILURE & RESILIENCE",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "71. Driver service down → fallback check",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx (except 503 fallback)\", () => { pm.expect(pm.response.code).to.not.equal(500); });",
							"pm.test(\"Handled via fallback (200 or 503)\", () => {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 503]);",
							"    if (pm.response.code === 200) {",
							"        pm.expect(pm.response.json().success).to.be.true;",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_driver_down\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "72. Pricing service timeout → retry/fallback",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.not.equal(500); });",
							"pm.test(\"Resiliency: Handled via 201 or 503\", () => {",
							"    pm.expect(pm.response.code).to.be.oneOf([201, 503]);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_pricing_timeout\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "73. AI fallback (Rule-based)",
			"event": [{ "listen": "test", "script": { "exec": ["pm.test(\"Expect 201\", () => { pm.response.to.have.status(201); });"], "type": "text/javascript" } }],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"body": { "mode": "raw", "raw": "{\"pickup\": {\"lat\": 10, \"lng\": 106}, \"drop\": {\"lat\": 11, \"lng\": 107}, \"distance_km\": 5, \"simulate_ai_fallback\": true}", "options": { "raw": { "language": "json" } } },
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "74. Payment service timeout",
			"event": [{ "listen": "test", "script": { "exec": ["pm.test(\"Handled correctly\", () => { pm.expect(pm.response.code).to.be.oneOf([400, 201]); });"], "type": "text/javascript" } }],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"body": { "mode": "raw", "raw": "{\"pickup\": {\"lat\": 10, \"lng\": 106}, \"drop\": {\"lat\": 11, \"lng\": 107}, \"distance_km\": 5, \"simulate_payment_timeout\": true}", "options": { "raw": { "language": "json" } } },
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "75. Circuit breaker open (Repetitive failures)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Circuit Breaker Triggered (503 Service Unavailable)\", () => {",
							"    pm.response.to.have.status(503);",
							"    pm.expect(pm.response.json().message).to.include(\"Circuit\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_circuit_open\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "76. Kafka partition failover",
			"event": [{ "listen": "test", "script": { "exec": ["pm.test(\"200 OK\", () => { pm.response.to.have.status(200); });"], "type": "text/javascript" } }],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/health?simulate_kafka_failover=1", "host": ["{{baseUrl}}"], "path": ["health"] }
			}
		},
		{
			"name": "77. API Retry with Jitter",
			"event": [{ "listen": "test", "script": { "exec": ["pm.test(\"201 Created\", () => { pm.response.to.have.status(201); });"], "type": "text/javascript" } }],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"body": { "mode": "raw", "raw": "{\"pickup\": {\"lat\": 10, \"lng\": 106}, \"drop\": {\"lat\": 11, \"lng\": 107}, \"distance_km\": 5}", "options": { "raw": { "language": "json" } } },
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "78. Service discovery resilience",
			"event": [{ "listen": "test", "script": { "exec": ["pm.test(\"200 OK\", () => { pm.response.to.have.status(200); });"], "type": "text/javascript" } }],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/health-booking", "host": ["{{baseUrl}}"], "path": ["health-booking"] }
			}
		},
		{
			"name": "79. DB pool exhaustion check",
			"event": [{ "listen": "test", "script": { "exec": ["pm.test(\"Code 500 or 503 is acceptable, must not crash\", () => { pm.expect(pm.response.code).to.be.oneOf([500, 503]); });"], "type": "text/javascript" } }],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"body": { "mode": "raw", "raw": "{\"pickup\": {\"lat\": 10, \"lng\": 106}, \"drop\": {\"lat\": 11, \"lng\": 107}, \"distance_km\": 5, \"simulate_db_error\": true}", "options": { "raw": { "language": "json" } } },
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "80. Graceful degradation check",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"System still performs core functions under stress\", () => {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
							"    pm.expect(pm.response.json().success).to.be.true;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_stress\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "accessToken", "value": "" }
	]
}
