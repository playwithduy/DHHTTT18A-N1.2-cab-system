	"item": [
		{
			"name": "71. Driver service down → fallback",
			"event": [{ "listen": "test", "script": { "exec": ["pm.test(\"Handled via fallback\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 503]); });"], "type": "text/javascript" } }],
			"request": {
				"method": "POST",
				"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" }],
				"body": { "mode": "raw", "raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_driver_down\": true\n}", "options": { "raw": { "language": "json" } } },
