{
	"info": {
		"_postman_id": "level12-monitoring-observability",
		"name": "LEVEL 12 – MONITORING & OBSERVABILITY",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "111. Logging & Distrubuted Tracing (Header Check)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Status is 200 OK\", () => { pm.response.to.have.status(200); });",
							"pm.test(\"Tracing Header exists (X-Trace-ID)\", () => {",
							"    var traceId = pm.response.headers.get('X-Trace-ID') || pm.response.headers.get('x-trace-id');",
							"    pm.expect(traceId).to.be.ok;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
			}
		},
		{
			"name": "113. Metrics Exposure check",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Status is 200 OK\", () => { pm.response.to.have.status(200); });",
							"pm.test(\"Contains domain-specific metrics\", () => {",
							"    pm.expect(pm.response.text()).to.include(\"cabgo_\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": { "raw": "{{baseUrl}}/metrics", "host": ["{{baseUrl}}"], "path": ["metrics"] }
			}
		},
		{
			"name": "118. AI Observability check (Latency & Version)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Status is 200 OK\", () => { pm.response.to.have.status(200); });",
							"var jsonData = pm.response.json();",
							"pm.test(\"Observability Metadata exists\", () => {",
							"    var data = jsonData.data || jsonData;",
							"    pm.expect(data.modelVersion || data.version).to.be.ok;",
							"    pm.expect(data.latencyMs || data.responseTime).to.be.a('number');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\"pickup\":{\"lat\":10,\"lng\":106},\"distance_km\":5}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/match", "host": ["{{baseUrl}}"], "path": ["match"] }
			}
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "accessToken", "value": "" }
	]
}
