{
	"info": {
		"_postman_id": "c1a2b3c4-d5e6-4f7g-8h9i-j0k1l2m3n4o5",
		"name": "LEVEL 2 – VALIDATION & EDGE CASES",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "LEVEL 1 - BẢN TIN CƠ BẢN",
			"item": [
				{
					"name": "1. Đăng ký user thành công",
					"event": [
						{
							"listen": "prerequest",
							"script": { "exec": ["var randomInt = pm.variables.replaceIn('{{$randomInt}}'); pm.collectionVariables.set(\"testEmail\", \"user_lv2_\" + randomInt + \"@test.com\");"], "type": "text/javascript" }
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{testEmail}}\",\n    \"password\": \"123456\",\n    \"name\": \"Test User\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
					}
				},
				{
					"name": "2. Đăng nhập trả JWT hợp lệ",
					"event": [
						{
							"listen": "test",
							"script": { "exec": ["var jsonData = pm.response.json(); pm.collectionVariables.set(\"accessToken\", jsonData.data.access_token);"], "type": "text/javascript" }
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{testEmail}}\",\n    \"password\": \"123456\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
					}
				},
				{
					"name": "3. Tạo booking với input hợp lệ",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n    \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n    \"distance_km\": 5\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
					}
				}
			]
		},
		{
			"name": "LEVEL 2 - VALIDATION & EDGE CASES",
			"item": [
				{
					"name": "11. Booking thiếu pickup -> lỗi 400",
					"event": [
						{
							"listen": "test",
							"script": { "exec": [
								"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
								"pm.test(\"Returns 400 Bad Request\", () => { pm.response.to.have.status(400); });",
								"pm.test(\"Error message present\", () => { pm.expect(pm.response.json().message).to.include(\"required\"); });"
							], "type": "text/javascript" }
						}
					],
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n    \"distance_km\": 5\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
					}
				},
				{
					"name": "12. Sai format lat/lng → reject",
					"event": [
						{
							"listen": "test",
							"script": { "exec": [
								"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
								"pm.test(\"Returns 422 Unprocessable\", () => { pm.response.to.have.status(422); });"
							], "type": "text/javascript" }
						}
					],
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"pickup\": {\"lat\": \"abc\", \"lng\": 106.66},\n    \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n    \"distance_km\": 5\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
					}
				},
				{
					"name": "13. Driver offline không nhận booking",
					"event": [
						{
							"listen": "test",
							"script": { "exec": [
								"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
								"pm.test(\"Returns 200 with success false\", () => {",
								"    var jsonData = pm.response.json();",
								"    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
								"    if (pm.response.code === 200) pm.expect(jsonData.success).to.be.false;",
								"});"
							], "type": "text/javascript" }
						}
					],
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"pickup\": {\"lat\": 0, \"lng\": 0},\n    \"drop\": {\"lat\": 1, \"lng\": 1},\n    \"distance_km\": 100\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
					}
				},
				{
					"name": "14. Payment method invalid → reject",
					"event": [
						{
							"listen": "test",
							"script": { "exec": [
								"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
								"pm.test(\"Returns 400 Bad Request\", () => { pm.response.to.have.status(400); });",
								"pm.test(\"Error message present\", () => { pm.expect(pm.response.json().message).to.include(\"payment method\"); });"
							], "type": "text/javascript" }
						}
					],
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n    \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n    \"distance_km\": 5,\n    \"payment_method\": \"invalid_card\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
					}
				},
				{
					"name": "15. ETA với distance = 0",
					"event": [
						{
							"listen": "test",
							"script": { "exec": [
								"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
								"pm.test(\"Returns 200 OK\", () => { pm.response.to.have.status(200); });",
								"pm.test(\"ETA is non-negative\", () => {",
								"    var jsonData = pm.response.json();",
								"    pm.expect(jsonData.success).to.be.true;",
								"    var eta = jsonData.data.eta || jsonData.eta || 0;",
								"    pm.expect(eta).to.be.at.least(0);",
								"});"
							], "type": "text/javascript" }
						}
					],
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"distance_km\": 0\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/eta", "host": ["{{baseUrl}}"], "path": ["eta"] }
					}
				},
				{
					"name": "16. Pricing với demand_index = 0",
					"event": [
						{
							"listen": "test",
							"script": { "exec": [
								"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
								"pm.test(\"Returns 200 OK\", () => { pm.response.to.have.status(200); });",
								"pm.test(\"Surge is at least 1\", () => {",
								"    var jsonData = pm.response.json();",
								"    pm.expect(jsonData.success).to.be.true;",
								"    var surge = jsonData.data.surge_multiplier || jsonData.surge_multiplier || 1;",
								"    pm.expect(surge).to.be.at.least(1);",
								"});"
							], "type": "text/javascript" }
						}
					],
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"distance_km\": 5,\n    \"demand_index\": 0,\n    \"supply_index\": 1\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/pricing", "host": ["{{baseUrl}}"], "path": ["pricing"] }
					}
				},
				{
					"name": "17. Fraud API với input thiếu field",
					"event": [
						{
							"listen": "test",
							"script": { "exec": [
								"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
								"pm.test(\"Returns 400 Bad Request\", () => { pm.response.to.have.status(400); });"
							], "type": "text/javascript" }
						}
					],
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"user_id\": \"USR123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/fraud/check", "host": ["{{baseUrl}}"], "path": ["fraud", "check"] }
					}
				},
				{
					"name": "18. Token expired -> 401",
					"event": [
						{
							"listen": "test",
							"script": { "exec": [
								"pm.test(\"Returns 401 Unauthorized\", () => { pm.response.to.have.status(401); });"
							], "type": "text/javascript" }
						}
					],
					"request": {
						"header": [{ "key": "Authorization", "value": "Bearer expired_token_here" }],
						"method": "GET",
						"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
					}
				},
				{
					"name": "19. Duplicate booking request (idempotency)",
					"event": [
						{
							"listen": "test",
							"script": { "exec": [
								"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
								"pm.test(\"Returns 200 or 201\", () => { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
								"var jsonData = pm.response.json();",
								"pm.test(\"Idempotency Check: Returns existing record\", () => {",
								"    pm.expect(jsonData.success).to.be.true;",
								"    pm.expect(jsonData.id || jsonData.data.id).to.be.a('string');",
								"});"
							], "type": "text/javascript" }
						}
					],
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
						"header": [{ "key": "x-idempotency-key", "value": "test-key-123-{{$randomInt}}" }],
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n    \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n    \"distance_km\": 5\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
					}
				},
				{
					"name": "20. Input quá lớn (payload size test)",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"data\": \"huge_string_here...\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
					}
				}
			]
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "accessToken", "value": "" }
	]
}
