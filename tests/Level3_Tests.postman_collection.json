{
	"info": {
		"_postman_id": "step-by-step-level-3-id",
		"name": "LEVEL 3 – INTEGRATION TEST",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "21. Booking -> gọi ETA service thành công",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Booking successful\", () => { pm.response.to.have.status(201); });",
							"var jsonData = pm.response.json();",
							"pm.collectionVariables.set(\"bookingId\", jsonData.data.id || jsonData.data.booking_id);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"body": {
					"mode": "raw",
					"raw": "{\n    \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n    \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n    \"distance_km\": 5\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "22. Booking -> gọi Pricing service",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Pricing validation success\", () => {",
							"    pm.response.to.have.status(200);",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.data.price).to.be.above(0);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/bookings/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["bookings", "{{bookingId}}"] }
			}
		},
		{
			"name": "23. AI Agent chọn driver từ Driver Service",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Driver assigned check\", () => {",
							"     pm.response.to.have.status(200);",
							"     var jsonData = pm.response.json();",
							"     pm.expect(jsonData.data.driverId || jsonData.data.driver_id).to.not.be.null;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/bookings/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["bookings", "{{bookingId}}"] }
			}
		},
		{
			"name": "24. Booking -> Payment -> Notification flow",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Full flow status check\", () => {",
							"    pm.response.to.have.status(200);",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.data.status).to.eql(\"REQUESTED\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/bookings/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["bookings", "{{bookingId}}"] }
			}
		},
		{
			"name": "25. Kafka event ride_requested được publish",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Valid 200 list\", () => { pm.response.to.have.status(200); });",
							"var jsonData = pm.response.json();",
							"pm.test(\"Kafka Outbox contains event\", () => {",
							"    var found = false;",
							"    var bId = pm.variables.get(\"bookingId\");",
							"    if (jsonData.data) {",
							"        for(let ev of jsonData.data) {",
							"             if (ev.payload.includes(bId) && ev.payload.includes('ride_pending_payment')) found = true;",
							"        }",
							"    }",
							"    pm.expect(found).to.be.true;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/bookings/outbox", "host": ["{{baseUrl}}"], "path": ["bookings", "outbox"] }
			}
		},
		{
			"name": "26. Driver nhận notification",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"console.log('Sleeping for 3 seconds to allow Kafka & Outbox processing...');",
							"var targetTime = new Date().getTime() + 3000;",
							"while (new Date().getTime() < targetTime) { ; }"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Valid 200 list\", () => { pm.response.to.have.status(200); });",
							"var jsonData = pm.response.json();",
							"pm.test(\"Notification logs contain dispatch\", () => {",
							"    var found = false;",
							"    var bId = pm.variables.get(\"bookingId\");",
							"    if (jsonData.data) {",
							"        for(let ev of jsonData.data) {",
							"             if (ev.ride_id === bId && ev.type === 'notify_drivers') found = true;",
							"        }",
							"    }",
							"    pm.expect(found).to.be.true;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/notifications/logs", "host": ["{{baseUrl}}"], "path": ["notifications", "logs"] }
			}
		},
		{
			"name": "27. Booking update trạng thái ACCEPTED",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Status updated successfully\", () => { pm.response.to.have.status(200); });",
							"var jsonData = pm.response.json();",
							"pm.test(\"Status transitioned to ACCEPTED\", () => {",
							"    pm.expect(jsonData.data.status).to.eql(\"ACCEPTED\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "PATCH",
				"body": {
					"mode": "raw",
					"raw": "{\n    \"status\": \"ACCEPTED\",\n    \"driverId\": \"DRV_TEST_789\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings/{{bookingId}}/status", "host": ["{{baseUrl}}"], "path": ["bookings", "{{bookingId}}", "status"] }
			}
		},
		{
			"name": "28. MCP context được fetch thành công",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"var jsonData = pm.response.json();",
							"pm.test(\"AI Context: reasoning exists\", () => {",
							"    pm.expect(jsonData.data.matchingReason).to.be.a('string');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/bookings/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["bookings", "{{bookingId}}"] }
			}
		},
		{
			"name": "29. API Gateway route đúng service",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Gateway healthy\", function () { pm.response.to.have.status(200); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
			}
		},
		{
			"name": "30. Retry khi Pricing service timeout",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"System did not crash (Fail-Fast)\", () => { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
							"pm.test(\"Fallback applied or Timeout handled gracefully\", () => {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"});",
							"pm.test(\"Response time is acceptable (Fallback fired)\", () => {",
							"    pm.expect(pm.response.responseTime).to.be.below(4500);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"body": {
					"mode": "raw",
					"raw": "{\n    \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n    \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n    \"distance_km\": 5,\n    \"simulate_pricing_timeout\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "accessToken", "value": "" },
		{ "key": "bookingId", "value": "" }
	]
}
