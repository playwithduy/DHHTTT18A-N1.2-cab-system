{
	"info": {
		"_postman_id": "level7-perf-load",
		"name": "LEVEL 7 – PERFORMANCE & LOAD TEST",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "61. System Health Check (Baseline)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"System is healthy\", () => { pm.response.to.have.status(200); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
			}
		},
		{
			"name": "67. API Gateway rate limit check",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Expect 200 or 429\", () => {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 429]);",
							"    if (pm.response.code === 429) {",
							"        pm.expect(pm.response.json().message).to.include(\"Too many\");",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
			}
		},
		{
			"name": "68. Latency SLA check (< 300ms)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Response time is within SLA (300ms)\", () => {",
							"    pm.expect(pm.response.responseTime).to.be.below(300);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
			}
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" }
	]
}
