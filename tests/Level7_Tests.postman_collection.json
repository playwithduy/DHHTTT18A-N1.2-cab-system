{
  "info": {
    "_postman_id": "level7-performance-full",
    "name": "LEVEL 7 – PERFORMANCE & LOAD TEST (FULL 61-70)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "0. Đăng ký user (Dynamic)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var ts = new Date().getTime();",
              "pm.collectionVariables.set(\"userEmail\", \"user_lv7_\" + ts + \"@test.com\");"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Register success\", () => { pm.response.to.have.status(201); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"{{userEmail}}\",\n    \"password\": \"123456\",\n    \"name\": \"User Level 7\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        }
      }
    },
    {
      "name": "0. Đăng nhập trả JWT (Dynamic)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Login success\", () => { pm.response.to.have.status(200); });",
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set(\"accessToken\", jsonData.data.access_token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"{{userEmail}}\",\n    \"password\": \"123456\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "0. Driver Setup (Online)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"driver_id\": \"D_PERF_TEST\",\n    \"status\": \"ONLINE\",\n    \"location\": {\"lat\": 10.7626, \"lng\": 106.6602}\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/drivers/status",
          "host": ["{{baseUrl}}"],
          "path": ["drivers", "status"]
        }
      }
    },
    {
      "name": "61. Load Test (1000 requests simulator)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n    \"drop\": {\"lat\": 10.77, \"lng\": 106.67},\n    \"idempotency_key\": \"perf-{{$guid}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/bookings",
          "host": ["{{baseUrl}}"],
          "path": ["bookings"]
        }
      }
    },
    {
      "name": "62. ETA Service Load (500 req/sec)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"distance_km\": 5.5\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/eta",
          "host": ["{{baseUrl}}"],
          "path": ["eta"]
        }
      }
    },
    {
      "name": "63. Pricing Service Spike",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"distance_km\": 10.5,\n    \"demand_index\": 2.5\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/pricing",
          "host": ["{{baseUrl}}"],
          "path": ["pricing"]
        }
      }
    },
    {
      "name": "64. Kafka Throughput Verification",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/bookings/outbox",
          "host": ["{{baseUrl}}"],
          "path": ["bookings", "outbox"]
        }
      }
    },
    {
      "name": "65. DB Pool Exhaustion Test",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/bookings",
          "host": ["{{baseUrl}}"],
          "path": ["bookings"]
        }
      }
    },
    {
      "name": "66. Redis Cache Hit Rate Test",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Fast Response (< 20ms)\", () => { pm.expect(pm.response.responseTime).to.be.below(20); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n    \"drop\": {\"lat\": 10.77, \"lng\": 106.67},\n    \"idempotency_key\": \"fixed-cache-key-level7\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/bookings",
          "host": ["{{baseUrl}}"],
          "path": ["bookings"]
        }
      }
    },
    {
      "name": "67. API Gateway Rate Limit (Trigger 429)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "68. P95 Latency Metrics Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/metrics",
          "host": ["{{baseUrl}}"],
          "path": ["metrics"]
        }
      }
    },
    {
      "name": "69. Load Test Ramping (Peak Simulation)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "70. Auto Scaling Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "userEmail", "value": "" }
  ]
}
