		{
			"name": "95. RBAC – user không có quyền",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 403 or 401\", function () { pm.expect(pm.response.code).to.be.oneOf([401, 403]); });",
							"var msg = pm.response.json().message || ''; pm.test(\"Message indicates no access\", function () { pm.expect(msg).to.satisfy(m => m.includes('Forbidden') || m.includes('Access denied') || m.includes('Unauthorized') || m.includes('Missing') || m.includes('Invalid')); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{USER_TOKEN}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/admin/stats",
					"host": ["{{baseUrl}}"],
					"path": ["admin", "stats"]
				}
			},
			"response": []
		},
		{
