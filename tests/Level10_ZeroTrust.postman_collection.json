							"pm.test(\"Status is 403 or 401\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 401, 403]); });",
							"var msg = (pm.response.json().message || ''); pm.test(\"Message indicates no access or data returned\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 401, 403]); });"
						],
