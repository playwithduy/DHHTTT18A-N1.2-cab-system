{
	"info": {
		"_postman_id": "level10-zero-trust-security",
		"name": "LEVEL 10 – ZERO TRUST SECURITY",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "91. Request không có token → 401",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Expect 401 Unauthorized\", () => { pm.response.to.have.status(401); });",
							"pm.test(\"No 5xx error\", () => { pm.expect(pm.response.code).to.be.below(500); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "92. Token không hợp lệ (tampered) → 401",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Expect 401 Unauthorized\", () => { pm.response.to.have.status(401); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "Bearer tempered.payload.now", "type": "text" }
				],
				"url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
			}
		},
		{
			"name": "93. Token hết hạn → 401",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Expect 401 Unauthorized\", () => { pm.response.to.have.status(401); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{ "key": "Authorization", "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyLCJleHAiOjE1MTYyMzkwMjN9.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c", "type": "text" }
				],
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "95. RBAC – User truy cập Admin API → 403",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Forbidden for non-admin role (403)\", () => { pm.response.to.have.status(403); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/admin/stats", "host": ["{{baseUrl}}"], "path": ["admin", "stats"] }
			}
		},
		{
			"name": "96. Cross-Tenant – Driver truy cập user booking → 403",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const getReq = {",
							"    url: pm.variables.get(\"baseUrl\") + '/bookings',",
							"    method: 'GET',",
							"    header: { 'Authorization': 'Bearer ' + pm.variables.get(\"accessToken\") }",
							"};",
							"pm.sendRequest(getReq, (err, res) => {",
							"    if (!err && res.code === 200) {",
							"        const jsonData = res.json();",
							"        if (jsonData && jsonData.data && jsonData.data.length > 0) {",
							"            pm.collectionVariables.set(\"bookingId\", jsonData.data[0].id);",
							"            return;",
							"        }",
							"    }",
							"    const postReq = {",
							"        url: pm.variables.get(\"baseUrl\") + '/bookings',",
							"        method: 'POST',",
							"        header: {",
							"            'Content-Type': 'application/json',",
							"            'Authorization': 'Bearer ' + pm.variables.get(\"accessToken\")",
							"        },",
							"        body: {",
							"            mode: 'raw',",
							"            raw: JSON.stringify({ pickup: { lat: 10, lng: 106 }, drop: { lat: 11, lng: 107 }, distance_km: 5, vehicleType: 'car' })",
							"        }",
							"    };",
							"    pm.sendRequest(postReq, (err2, res2) => {",
							"        if (!err2) {",
							"            const jD = res2.json();",
							"            if (jD && jD.data && jD.data.id) {",
							"                pm.collectionVariables.set(\"bookingId\", jD.data.id);",
							"            }",
							"        }",
							"    });",
							"});"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Unauthorized or Forbidden access to other's data\", () => {",
							"    if (!pm.collectionVariables.get(\"bookingId\")) pm.expect.fail(\"bookingId not set\");",
							"    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{DRIVER_TOKEN}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/bookings/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["bookings", "{{bookingId}}"] }
			}
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "accessToken", "value": "" },
		{ "key": "bookingId", "value": "" }
	]
}
