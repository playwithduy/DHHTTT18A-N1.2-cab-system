		{
			"name": "91. Request không có token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 401\", function () { pm.response.to.have.status(401); });",
							"pm.test(\"Message is Missing token\", function () { pm.expect(pm.response.json().message).to.eql(\"Missing token\"); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/bookings",
					"host": ["{{baseUrl}}"],
					"path": ["bookings"]
				}
			},
			"response": []
