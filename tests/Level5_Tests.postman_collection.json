{
	"info": {
		"_postman_id": "level5-ai-validation",
		"name": "LEVEL 5 – AI SERVICE VALIDATION",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "41. ETA model output trong range hợp lý",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Status is 200 OK\", () => { pm.response.to.have.status(200); });",
							"var jsonData = pm.response.json();",
							"pm.test(\"ETA is logical (1-60 mins)\", () => {",
							"    pm.expect(jsonData.data.eta).to.be.within(1, 60);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"distance_km\": 5,\n  \"traffic_level\": 0.5\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/eta", "host": ["{{baseUrl}}"], "path": ["eta"] }
			}
		},
		{
			"name": "42. Pricing surge capping check",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Status is 200 OK\", () => { pm.response.to.have.status(200); });",
							"var jsonData = pm.response.json();",
							"pm.test(\"Surge is capped at 3.0\", () => {",
							"    pm.expect(jsonData.data.multiplier || jsonData.data.surge_multiplier).to.eql(3);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"distance_km\": 10,\n  \"demand_index\": 5,\n  \"supply_index\": 1\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/pricing", "host": ["{{baseUrl}}"], "path": ["pricing"] }
			}
