						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Status is 200 OK\", () => { pm.response.to.have.status(200); });",
							"var jsonData = pm.response.json();",
							"pm.test(\"Fraud flagged correctly\", () => {",
							"    pm.expect(jsonData.data.is_fraud).to.be.true;",
							"    pm.expect(jsonData.data.score).to.be.above(0.9);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
