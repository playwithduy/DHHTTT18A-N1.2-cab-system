		{
			"name": "49. Model fallback khi lỗi",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fallback logic active\", () => {",
							"    var jsonData = pm.response.json();",
							"    var fallback = jsonData.isFallback || (jsonData.data && jsonData.data.isFallback);",
							"    pm.expect(fallback).to.be.true;",
							"    pm.expect(jsonData.reasoning || jsonData.data.reasoning).to.include(\"FALLBACK\");",
							"});"
						],
