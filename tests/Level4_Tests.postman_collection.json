{
	"info": {
		"_postman_id": "level4-sequential-verification",
		"name": "LEVEL 4 - TRANSACTION",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "31. Transaction tạo booking thành công",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 201 or 200\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
							"});",
							"var jsonData = pm.response.json();",
							"if (jsonData.success) {",
							"    pm.environment.set(\"last_booking_id\", jsonData.data.id || jsonData.data.booking_id);",
							"    pm.test(\"Status is REQUESTED\", function () {",
							"        pm.expect(jsonData.data.status).to.eql(\"REQUESTED\");",
							"    });",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "Bearer {{access_token}}" },
					{ "key": "x-idempotency-key", "value": "idemp-31-{{$randomInt}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/bookings", "host": ["{{base_url}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "32. Rollback khi lỗi giữa chừng",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 500 or 400\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([400, 500]);",
							"});",
							"pm.test(\"Error message matches\", function () {",
							"    var msg = pm.response.json().message || pm.response.json().error || '';",
							"    pm.expect(msg.length).to.be.above(0);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "Bearer {{access_token}}" },
					{ "key": "x-idempotency-key", "value": "rollback-32-{{$randomInt}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_db_error\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/bookings", "host": ["{{base_url}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "33. Payment thất bại → rollback booking",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 400 or 201\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 500]);",
							"});",
							"pm.test(\"Booking marked as FAILED or REQUESTED\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 500]);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "Bearer {{access_token}}" },
					{ "key": "x-idempotency-key", "value": "payfail-33-{{$randomInt}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_payment_failure\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/bookings", "host": ["{{base_url}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "34. Idempotent transaction (duplicate request)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 200 or 201 (Idempotent)\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
							"});",
							"var jsonData = pm.response.json();",
							"pm.test(\"Returned data is valid\", function () {",
							"    pm.expect(jsonData.success).to.be.true;",
							"    pm.expect(jsonData.data).to.exist;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "Bearer {{access_token}}" },
					{ "key": "x-idempotency-key", "value": "fixed-idemp-34" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/bookings", "host": ["{{base_url}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "35. Concurrent booking (race condition)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Expected 201 or 429\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([201, 429]);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "Bearer {{access_token}}" },
					{ "key": "x-idempotency-key", "value": "race-35-{{$randomInt}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/bookings", "host": ["{{base_url}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "36. Saga transaction – success flow",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Booking exists and is REQUESTED or in progress\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 404, 500]);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" } ],
				"url": { "raw": "{{base_url}}/bookings/{{last_booking_id}}", "host": ["{{base_url}}"], "path": ["bookings", "{{last_booking_id}}"] }
			}
		},
		{
			"name": "37. Saga transaction – failure + compensation",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 400 or 500\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 500]);",
							"});",
							"pm.test(\"Compensation: FAILED status returned\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 500]);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "Bearer {{access_token}}" },
					{ "key": "x-idempotency-key", "value": "saga-fail-37-{{$randomInt}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_payment_failure\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/bookings", "host": ["{{base_url}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "38. Kafka event consistency (outbox pattern)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 200\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
							"});",
							"pm.test(\"Outbox worker should process this event\", function () {",
							"    pm.expect(pm.response.json().success).to.be.true;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "Bearer {{access_token}}" },
					{ "key": "x-idempotency-key", "value": "outbox-38-{{$randomInt}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/bookings", "host": ["{{base_url}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "39. Partial failure (network issue)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 400 or 201 (Timeout handled)\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 500]);",
							"});",
							"pm.test(\"Error message is clear\", function () {",
							"    var msg = pm.response.json().message || pm.response.json().error || '';",
							"    pm.expect(msg.length).to.be.above(0);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "Bearer {{access_token}}" },
					{ "key": "x-idempotency-key", "value": "timeout-39-{{$randomInt}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_payment_timeout\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/bookings", "host": ["{{base_url}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "40. Data integrity (ACID)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Audit check passed\", function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 500]);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" } ],
				"url": { "raw": "{{base_url}}/bookings", "host": ["{{base_url}}"], "path": ["bookings"] }
			}
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": { "type": "text/javascript", "exec": [""] }
		},
		{
			"listen": "test",
			"script": { "type": "text/javascript", "exec": [""] }
		}
	],
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8080" },
		{ "key": "access_token", "value": "YOUR_TOKEN_HERE" },
		{ "key": "last_booking_id", "value": "" }
	]
}
