{
	"info": {
		"_postman_id": "level4-sequential-verification",
		"name": "LEVEL 4 - TRANSACTION",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "0. Đăng ký user (Dynamic)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"var ts = new Date().getTime();",
							"pm.collectionVariables.set(\"userEmail\", \"user_lv4_\" + ts + \"@test.com\");"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Register success\", () => { pm.response.to.have.status(201); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{userEmail}}\",\n    \"password\": \"123456\",\n    \"name\": \"User Level 4\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
			}
		},
		{
			"name": "0. Đăng nhập trả JWT (Dynamic)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Login success\", () => { pm.response.to.have.status(200); });",
							"var jsonData = pm.response.json();",
							"pm.collectionVariables.set(\"accessToken\", jsonData.data.access_token);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{userEmail}}\",\n    \"password\": \"123456\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
			}
		},
		{
			"name": "0. Driver ONLINE (Setup)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Driver online success\", () => { pm.response.to.have.status(200); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"body": {
					"mode": "raw",
					"raw": "{\n    \"driver_id\": \"DRV_LV4_PM\",\n    \"status\": \"ONLINE\",\n    \"location\": {\"lat\": 10.76, \"lng\": 106.66}\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/drivers/status", "host": ["{{baseUrl}}"], "path": ["drivers", "status"] }
			}
		},
		{
			"name": "31. Transaction tạo booking thành công",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not unexpected 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Booking created successfully\", () => { pm.response.to.have.status(201); });",
							"var jsonData = pm.response.json();",
							"pm.test(\"Status is REQUESTED\", () => {",
							"    pm.expect(jsonData.success).to.be.true;",
							"    pm.expect(jsonData.data.status).to.eql(\"REQUESTED\");",
							"});",
							"pm.collectionVariables.set(\"lastBookingId\", jsonData.data.id || jsonData.data.booking_id);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"header": [
					{ "key": "x-idempotency-key", "value": "idemp-31-{{$randomInt}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "32. Rollback khi lỗi giữa chừng (DB Error)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"pm.variables.set(\"idemp_tc32\", \"rollback-32-\" + Math.random());"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Expected Simulated DB Error (500)\", () => { pm.response.to.have.status(500); });",
							"pm.test(\"Error message is clear\", () => {",
							"    var msg = pm.response.json().message || '';",
							"    pm.expect(msg).to.include(\"DB_ERROR\");",
							"});",
							"pm.test(\"Rollback verification: DB is clean\", (done) => {",
							"    const req = {",
							"        url: pm.variables.get(\"baseUrl\") + '/bookings',",
							"        method: 'GET',",
							"        header: { 'Authorization': 'Bearer ' + pm.variables.get('accessToken') }",
							"    };",
							"    pm.sendRequest(req, (err, res) => {",
							"        if (err) throw err;",
							"        let found = false;",
							"        const idemp = pm.variables.get(\"idemp_tc32\");",
							"        for (let b of res.json().data) {",
							"            if (b.idempotencyKey === idemp) found = true;",
							"        }",
							"        pm.expect(found).to.be.false;",
							"        done();",
							"    });",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"header": [
					{ "key": "x-idempotency-key", "value": "{{idemp_tc32}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_db_error\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "33. Payment thất bại → rollback booking",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Returns 400 Bad Request\", () => { pm.response.to.have.status(400); });",
							"var jsonData = pm.response.json();",
							"pm.test(\"Booking marked as CANCELLED\", () => {",
							"    pm.expect(jsonData.success).to.be.false;",
							"    pm.expect(jsonData.data.status).to.eql(\"CANCELLED\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"header": [
					{ "key": "x-idempotency-key", "value": "payfail-33-{{$randomInt}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_payment_failure\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "34. Idempotent transaction (duplicate check)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"pm.collectionVariables.set(\"dynamic_idemp_key\", \"idemp-key-\" + Date.now() + \"-\" + Math.random());"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 201 Created (First unique key)\", () => { pm.response.to.have.status(201); });",
							"var firstId = pm.response.json().data.id;",
							"pm.collectionVariables.set(\"idemp_test_id\", firstId);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"header": [
					{ "key": "x-idempotency-key", "value": "{{dynamic_idemp_key}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "34.1 Re-send same key → expect same record",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 200 OK (Cached record returned)\", () => { pm.response.to.have.status(200); });",
							"var secondId = pm.response.json().data.id;",
							"pm.test(\"ID matches previous request\", () => {",
							"    pm.expect(secondId).to.eql(pm.collectionVariables.get(\"idemp_test_id\"));",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"header": [
					{ "key": "x-idempotency-key", "value": "{{dynamic_idemp_key}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "35. Concurrent booking (race condition)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Expected 409 Conflict\", () => { pm.response.to.have.status(409); });",
							"pm.test(\"Error message is clear\", () => {",
							"    pm.expect(pm.response.json().message).to.include(\"in progress\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"header": [
					{ "key": "x-idempotency-key", "value": "race-35-{{$randomInt}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_race_condition\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "36. Saga transaction – success flow",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Booking exists and is REQUESTED\", () => {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(pm.response.json().data.status).to.eql(\"REQUESTED\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/bookings/{{lastBookingId}}", "host": ["{{baseUrl}}"], "path": ["bookings", "{{lastBookingId}}"] }
			}
		},
		{
			"name": "37. Saga transaction – failure + compensation check",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Returns 400 Bad Request\", () => { pm.response.to.have.status(400); });",
							"var jsonData = pm.response.json();",
							"pm.collectionVariables.set(\"failedBookingId\", jsonData.data.id || jsonData.data.booking_id);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"header": [
					{ "key": "x-idempotency-key", "value": "saga-fail-37-{{$randomInt}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_payment_failure\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "37.1 Verify compensation logic",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Booking record is marked CANCELLED\", () => {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(pm.response.json().data.status).to.eql(\"CANCELLED\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/bookings/{{failedBookingId}}", "host": ["{{baseUrl}}"], "path": ["bookings", "{{failedBookingId}}"] }
			}
		},
		{
			"name": "38. Kafka event consistency (outbox pattern)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 201\", () => { pm.response.to.have.status(201); });",
							"pm.test(\"Success is true\", () => { pm.expect(pm.response.json().success).to.be.true; });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "POST",
				"header": [
					{ "key": "x-idempotency-key", "value": "outbox-38-{{$randomInt}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "38.5 Register fresh user for Resilience Test",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"var ts = new Date().getTime();",
							"pm.collectionVariables.set(\"resilienceUserEmail\", \"user_resilience_\" + ts + \"@test.com\");"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Register success\", () => { pm.response.to.have.status(201); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{resilienceUserEmail}}\",\n    \"password\": \"123456\",\n    \"name\": \"Resilience User\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
			}
		},
		{
			"name": "38.6 Login fresh user",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Login success\", () => { pm.response.to.have.status(200); });",
							"var jsonData = pm.response.json();",
							"pm.collectionVariables.set(\"resilienceAccessToken\", jsonData.data.access_token);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{resilienceUserEmail}}\",\n    \"password\": \"123456\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
			}
		},
		{
			"name": "39. Partial failure (network timeout handling)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Expected 400 (Payment Timeout -> Rollback)\", () => { pm.response.to.have.status(400); });",
							"pm.test(\"Error message is clear\", () => {",
							"    var msg = pm.response.json().message;",
							"    pm.expect(msg).to.include(\"Payment failed\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{resilienceAccessToken}}", "type": "string" }] },
				"method": "POST",
				"header": [
					{ "key": "x-idempotency-key", "value": "timeout-39-{{$randomInt}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"drop\": {\"lat\": 10.77, \"lng\": 106.70},\n  \"distance_km\": 5,\n  \"simulate_payment_timeout\": true\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "40. Data integrity (Persistence check)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Audit check passed\", () => {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(pm.response.json().data).to.be.an('array');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
				"method": "GET",
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "accessToken", "value": "" },
		{ "key": "lastBookingId", "value": "" },
		{ "key": "failedBookingId", "value": "" },
		{ "key": "idemp_test_id", "value": "" }
	]
}
