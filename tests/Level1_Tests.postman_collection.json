	"item": [
		{
			"name": "1. Đăng ký user thành công",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Status is not 5xx\", () => { pm.response.to.not.be.error; });",
							"pm.test(\"Registration returns 201 Created\", () => { pm.response.to.have.status(201); });",
							"var jsonData = pm.response.json();",
							"pm.test(\"Schema Validation: Registration Success\", () => {",
							"    pm.expect(jsonData.success).to.be.true;",
							"    pm.expect(jsonData.user_id).to.be.a('string');",
							"    pm.expect(jsonData.data.access_token).to.be.a('string');",
							"});",
							"pm.collectionVariables.set(\"userId\", jsonData.user_id);",
							"pm.collectionVariables.set(\"accessToken\", jsonData.data.access_token);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"user@test.com\",\n    \"password\": \"123456\",\n    \"name\": \"Test User\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/auth/register",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"auth",
						"register"
					]
				}
			},
			"response": []
		},
