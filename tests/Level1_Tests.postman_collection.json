		{
			"name": "7. Gọi API ETA trả về giá trị > 0",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Status is not 5xx\", () => { pm.response.to.not.be.error; });",
							"pm.test(\"ETA returns 200 OK or 201\", () => { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
							"var jsonData = pm.response.json();",
							"pm.test(\"ETA is logical (> 0)\", () => {",
							"    var eta = jsonData.data.eta || jsonData.eta;",
							"    pm.expect(eta).to.be.above(0);",
							"});"
						],
						"type": "text/javascript"
					}
				}
