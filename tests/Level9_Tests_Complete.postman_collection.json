{
	"info": {
		"_postman_id": "level9-security-deep-logic",
		"name": "LEVEL 9 – SECURITY & DEEP LOGIC",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "81. SQL injection attempt (Login)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 500 (Potential vuln)\", () => { pm.expect(pm.response.code).to.not.equal(500); });",
							"pm.test(\"Rejected as Unauthorized or Bad Request\", () => {",
							"    pm.expect(pm.response.code).to.be.oneOf([400, 401, 422]);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"' OR 1=1 --\",\n    \"password\": \"anything\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
			}
		},
		{
			"name": "82. XSS input test (Register)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 500\", () => { pm.expect(pm.response.code).to.not.equal(500); });",
							"pm.test(\"Handled correctly (Sanitized or Rejected)\", () => {",
							"    pm.expect(pm.response.code).to.be.oneOf([201, 400]);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"hacker{{$randomInt}}@test.com\",\n    \"password\": \"password123\",\n    \"name\": \"<script>alert('hack')</script>\",\n    \"phone\": \"0912345678\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
			}
		},
		{
			"name": "83. JWT tampering check",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Tampered JWT rejected with 401\", () => {",
							"    pm.response.to.have.status(401);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{ "key": "Authorization", "value": "Bearer tempered.jwt.payload", "type": "text" }
				],
				"url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "84. Unauthorized Admin access",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Unauthorized access returns 401 or 403\", () => {",
							"    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": { "raw": "{{baseUrl}}/admin/stats", "host": ["{{baseUrl}}"], "path": ["admin", "stats"] }
			}
		},
		{
			"name": "89. RBAC enforcement (Driver accessing Admin)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Driver rejected from Admin with 403\", () => {",
							"    pm.response.to.have.status(403);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{ "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" }
				],
				"url": { "raw": "{{baseUrl}}/admin/stats", "host": ["{{baseUrl}}"], "path": ["admin", "stats"] }
			}
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "accessToken", "value": "" }
	]
}
