{
	"info": {
		"_postman_id": "level11-deployment-readiness",
		"name": "LEVEL 11 – DEPLOYMENT & READINESS",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "101. Deployment Readiness Check (Booking Service)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Check booking-service health\", () => {",
							"    pm.response.to.have.status(200);",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.service || jsonData.data.service).to.eql(\"booking-service\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
			}
		},
		{
			"name": "Metrics Check: Prometheus Schema Validation",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Status is 200 OK\", () => { pm.response.to.have.status(200); });",
							"pm.test(\"Metrics Data format is valid\", () => {",
							"    var body = pm.response.text();",
							"    pm.expect(body).to.satisfy((t) => t.includes('# HELP') || t.includes('cabgo_') || t.includes('process_'));",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": { "raw": "{{baseUrl}}/metrics", "host": ["{{baseUrl}}"], "path": ["metrics"] }
			}
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" }
	]
}
