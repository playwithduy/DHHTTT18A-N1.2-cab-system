              "var jsonData = pm.response.json();",
              "pm.test(\"DRV002 is excluded\", () => {",
              "    var drivers = jsonData.drivers || [];",
              "    var drv002 = drivers.find(d => d.driverId === 'DRV002');",
              "    pm.expect(drv002).to.be.undefined;",
              "});",
              "pm.test(\"Next best driver selected\", () => {",
              "    pm.expect(jsonData.driverId).to.not.equal('DRV002');",
