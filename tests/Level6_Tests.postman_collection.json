{
	"info": {
		"_postman_id": "level6-agent-logic",
		"name": "LEVEL 6 – AI AGENT LOGIC",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "51. Agent chọn driver gần nhất (Speed)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Fail-Fast: Code is not 5xx\", () => { pm.expect(pm.response.code).to.be.below(500); });",
							"pm.test(\"Status is 200 OK\", () => { pm.response.to.have.status(200); });",
							"var jsonData = pm.response.json();",
							"pm.test(\"Reasoning includes SPEED\", () => {",
							"    var reasoning = jsonData.reasoning || (jsonData.data && jsonData.data.matchingReason) || '';",
							"    pm.expect(reasoning.toUpperCase()).to.include(\"SPEED\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"pickup\": {\"lat\": 10.76, \"lng\": 106.66},\n  \"priority\": \"speed\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/match", "host": ["{{baseUrl}}"], "path": ["match"] }
			}
		},
